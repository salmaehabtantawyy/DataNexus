# ─────────────────────────────────────────────────────────
#  DataNexus — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit the .env file. It is already in .gitignore.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=datanexus
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=datanexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://datanexus:your_password_here@localhost:5432/datanexus

# ── Airflow ───────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_password_here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://datanexus:your_password_here@postgres:5432/airflow

# ── Flask API ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=your_flask_secret_key_here
API_PORT=5000

# ── Streamlit Dashboard ───────────────────────────────────
STREAMLIT_PORT=8501

# ── Alerting — Email (SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_FROM_EMAIL=your_email@gmail.com
ALERT_TO_EMAIL=team@example.com

# ── Alerting — Slack ─────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Great Expectations ────────────────────────────────────
GE_ROOT_DIR=great_expectations
